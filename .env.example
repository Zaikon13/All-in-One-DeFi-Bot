WEBHOOK_URL=https://bot-production-3d9c.up.railway.app

# 💬 TELEGRAM
TELEGRAM_BOT_TOKEN=**REDACTED**
TELEGRAM_CHAT_ID=5307877340

# 🔗 GITHUB / RAILWAY / OPENAI
GH_FINE_TOKEN=**REDACTED**
OPENAI_API_KEY=**REDACTED**
RAILWAY_API_KEY=**REDACTED**
ANTHROPIC_API_KEY=**REDACTED**

# ⚙️ BOT CONFIG
WALLET_ADDRESS=0xEa53D79ce2A915033e6b4C5ebE82bb6b292E35Cc
CRONOS_RPC_URL=https://cronos-evm-rpc.publicnode.com
DISCOVER_QUERY=cronos
EOD_TIME=23:59

# 📡 CRONOS EXPLORER API (live, keyed) — PRIMARY blockchain data source for /balances and /daily_pnl.
# Replaces the old keyless cronos.org/explorer/api feed that silently froze on 2026-05-22.
# Get a free key at the Cronos developer portal. Set the real value in Railway; keep it out of git.
CRONOS_EXPLORER_API_KEY=
# Optional: warn if wallet data is more than this many blocks behind the live chain (~200000 ≈ 1 day).
CRONOS_STALE_BLOCK_THRESHOLD=200000

# 📡 ETHERSCAN V2 (LEGACY — no longer used by the live /daily_pnl path; kept only for the deprecated sync Covalent helper)
ETHERSCAN_API_KEY=**REDACTED**

# 🐦 X (Twitter) API
# Για posting alerts/PnL στο X (χρειάζεται OAuth 1.0a User Context)
X_CONSUMER_KEY=**REDACTED**
X_CONSUMER_SECRET=**REDACTED**
X_ACCESS_TOKEN=**REDACTED**
X_ACCESS_TOKEN_SECRET=**REDACTED**